    <resultMap id="BaseResultMap" type="upc.c505.modular.ecochain.entity.EcoChainBuildWarehouse">
        <id column="id" property="id" />
        <result column="enterprise_name" property="enterpriseName" />
        <result column="social_credit_code" property="socialCreditCode" />
        <result column="batch_number" property="batchNumber" />
        <result column="eco_chain_type_configuration_id" property="ecoChainTypeConfigurationId" />
