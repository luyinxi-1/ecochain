<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="upc.c505.modular.ecochain.mapper.EcoChainProductClassificationMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="upc.c505.modular.ecochain.entity.EcoChainProductClassification">
        <id column="id" property="id" />
        <result column="product_classification_name" property="productClassificationName" />
        <result column="sort_number" property="sortNumber" />
        <result column="parent_id" property="parentId" />
        <result column="enterprise_name" property="enterpriseName" />
        <result column="social_credit_code" property="socialCreditCode" />
        <result column="area_id" property="areaId" />
        <result column="logo" property="logo" />
        <result column="type" property="type" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>
    <update id="updateProductClassification" parameterType="upc.c505.modular.ecochain.entity.EcoChainProductClassification">
        UPDATE eco_chain_product_classification
        <set>
            <if test="productClassificationName != null and productClassificationName != ''">
                product_classification_name = #{productClassificationName},
            </if>
            <if test="type != null and type != ''">
                type = #{type},
            </if>
            <if test="sortNumber != null">
                sort_number = #{sortNumber},
            </if>
            <if test="parentId != null">
                parent_id = #{parentId},
            </if>
            <if test="classificationGrade != null">
                classification_grade = #{classificationGrade},
            </if>
            <if test="enterpriseName != null and enterpriseName != ''">
                enterprise_name = #{enterpriseName},
            </if>
            <if test="socialCreditCode != null and socialCreditCode != ''">
                social_credit_code = #{socialCreditCode},
            </if>
            <if test="areaId != null">
                area_id = #{areaId},
            </if>
            <if test="operator != null and operator != ''">
                operator = #{operator},
            </if>
            <if test="operationDatetime != null">
                operation_datetime = #{operationDatetime},
            </if>
            <if test="logo != null and logo != ''">
                logo = #{logo},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    <select id="selectMaxSortNumber" resultType="java.lang.Integer" parameterType="upc.c505.modular.ecochain.entity.EcoChainProductClassification">
        SELECT MAX(sort_number) FROM eco_chain_product_classification
        <where>
            <if test="socialCreditCode != null and socialCreditCode != ''">
                social_credit_code = #{socialCreditCode}
            </if>
        </where>
    </select>


</mapper>
