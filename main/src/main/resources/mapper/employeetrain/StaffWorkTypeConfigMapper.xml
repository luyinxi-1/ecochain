<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="upc.c505.modular.employeetrain.mapper.StaffWorkTypeConfigMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="upc.c505.modular.employeetrain.entity.StaffWorkTypeConfig">
        <id column="id" property="id" />
        <result column="industry_type_id" property="industryTypeId" />
        <result column="industry_type" property="industryType" />
        <result column="work_type_id" property="workTypeId" />
        <result column="work_type" property="workType" />
        <result column="required_class_hour" property="requiredClassHour" />
        <result column="is_open" property="isOpen" />
        <result column="operate_person" property="operatePerson" />
        <result column="operate_ip" property="operateIp" />
        <result column="operation_datetime" property="operationDatetime" />
        <result column="staff_type_id" property="staffTypeId" />
        <result column="staff_type" property="staffType" />
        <result column="unified_code" property="unifiedCode" />
        <result column="add_datetime" property="addDatetime" />
        <result column="creator" property="creator" />
    </resultMap>
    <select id="getIndex" resultType="upc.c505.modular.employeetrain.entity.StaffWorkTypeConfig">
        select *
        from staff_work_type_config
        <trim prefix="where" prefixOverrides="and| or">
            <if test="param.workType != null and param.workType != ''">
                and work_type like concat('%',#{param.workType},'%')
            </if>
            <if test="param.industryType != null and param.industryType != ''">
                and industry_type like concat('%',#{param.industryType},'%')
            </if>
            <if test="param.isOpen != null and param.isOpen != ''">
                and is_open = #{param.isOpen}
            </if>
            <if test="param.multiParam != null and param.multiParam != ''">
                and ( industry_type like concat('%',#{param.multiParam},'%') or
                work_type like concat('%',#{param.multiParam},'%')
                )
            </if>
        </trim>
        <if test="param.isAscByOperateTime != null and param.isAscByOperateTime == 0">
            order by operation_datetime
        </if>
        <if test="param.isAscByOperateTime != null and param.isAscByOperateTime == 1">
            order by operation_datetime desc
        </if>
    </select>

</mapper>
