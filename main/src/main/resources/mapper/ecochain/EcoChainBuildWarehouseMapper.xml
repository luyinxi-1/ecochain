        <result column="eco_chain_regional_configuration_id" property="ecoChainRegionalConfigurationId" />
        <result column="industry_group_option" property="industryGroupOption" />
        <result column="industry_warehouse" property="industryWarehouse" />
        <result column="warahouse_contact" property="warahouseContact" />
        <result column="warahouse_phone" property="warahousePhone" />
        <result column="quantity" property="quantity" />
        <result column="notes" property="notes" />
        <result column="warahouse_pictures" property="warahousePictures" />
