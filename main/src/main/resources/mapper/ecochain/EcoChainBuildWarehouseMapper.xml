                operator = #{operator},
            </if>
            <if test="operationDatetime != null">
                operation_datetime = #{operationDatetime},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    <update id="finishWarehouse" parameterType="upc.c505.modular.ecochain.controller.param.EcoChainBuildWareHouseFinishParam">
        UPDATE eco_chain_build_warehouse
        <set>
            <if test="marketPricing != null">
                market_pricing = #{marketPricing},
            </if>
            <if test="warrantyPeriod != null and warrantyPeriod != ''">
                warranty_period = #{warrantyPeriod},
            </if>
