            </if>
            <if test="visiblePeopleName != null and visiblePeopleName != ''">
                visible_people_name = #{visiblePeopleName},
            </if>
            <if test="visiblePeople != null and visiblePeople != ''">
                visible_people = #{visiblePeople},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            <if test="marketPricing != null">
                market_pricing = #{marketPricing},
            </if>
            <if test="warrantyPeriod != null and warrantyPeriod != ''">
                warranty_period = #{warrantyPeriod},
            </if>
            <if test="otherDescription != null and otherDescription != ''">
