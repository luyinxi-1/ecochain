    <update id="updateStatusById">
        UPDATE eco_chain_build_warehouse
        SET status = #{status}, operation_datetime = #{now}, operator = #{userName}
        WHERE id = #{warehouseId}
    </update>

    <update id="updateByWarehouseId" parameterType="upc.c505.modular.ecochain.entity.EcoChainBuildWarehouse">
        UPDATE eco_chain_build_warehouse
        <set>
            <if test="enterpriseName != null and enterpriseName != ''">
                enterprise_name = #{enterpriseName},
            </if>
            <if test="socialCreditCode != null and socialCreditCode != ''">
                social_credit_code = #{socialCreditCode},
            </if>
            <if test="batchNumber != null and batchNumber != ''">
                batch_number = #{batchNumber},
            </if>
            <if test="ecoChainTypeConfigurationId != null and ecoChainTypeConfigurationId != ''">
                eco_chain_type_configuration_id = #{ecoChainTypeConfigurationId},
            </if>
            <if test="detailTypeOption != null and detailTypeOption != ''">
                detail_type_option = #{detailTypeOption},
            </if>
            <if test="ecoChainRegionalConfigurationId != null and ecoChainRegionalConfigurationId != ''">
                eco_chain_regional_configuration_id = #{ecoChainRegionalConfigurationId},
            </if>
            <if test="industryGroupOption != null and industryGroupOption != ''">
                industry_group_option = #{industryGroupOption},
            </if>
            <if test="industryWarehouse != null and industryWarehouse != ''">
                industry_warehouse = #{industryWarehouse},
            </if>
            <if test="isCase != null">
                is_case = #{isCase},
            </if>
            <if test="warahouseContact != null and warahouseContact != ''">
                warahouse_contact = #{warahouseContact},
            </if>
            <if test="warahousePhone != null and warahousePhone != ''">
                warahouse_phone = #{warahousePhone},
            </if>
            <if test="quantity != null">
                quantity = #{quantity},
            </if>
            <if test="notes != null and notes != ''">
