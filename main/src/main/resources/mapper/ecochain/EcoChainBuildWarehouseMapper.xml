    <update id="updateAllCompletionDatetime" parameterType="upc.c505.modular.ecochain.controller.param.EcoChainBuildWareHouseFinishParam">

        UPDATE eco_chain_build_warehouse
        SET all_completion_datetime = #{allCompletionDatetime}
        WHERE id = #{id}
    </update>


